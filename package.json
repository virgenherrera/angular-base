{
  "name": "angular-base",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "test": "pnpm run cleanup && pnpm run test:static && pnpm run test:dynamic && pnpm run build:app",
    "build": "pnpm run build:app",
    "build:app": "ng build",
    "test:doctor": "pnpm run cleanup && pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck && pnpm run test:dynamic && pnpm run build:app",
    "test:static": "pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck",
    "test:dynamic": "ng test --configuration=ci",
    "securityCheck": "pnpm audit --audit-level high",
    "eslintCheck": "eslint \"src/**/*.ts\"",
    "prettierCheck": "prettier --check \"{src,public}/**/*.{ts,js,json,css,html,md}\"",
    "prepare": "husky",
    "lintStaged": "lint-staged",
    "cleanup": "rimraf .angular/ coverage/ dist/",
    "securityFix": "pnpm update",
    "updatePnpm": "corepack up",
    "bumpDependencies": "pnpm run securityFix && pnpm dlx npm-check-updates@17 && pnpm run securityFix"
  },
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/router": "21.2.15",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "4.1.12",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "postcss": "8.5.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tailwindcss": "4.1.12",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
