{
  "name": "angular-base",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "test": "pnpm run cleanup && pnpm run test:static && pnpm run test:unit && pnpm run build:app",
    "build": "pnpm run build:app",
    "watch": "ng build --watch --configuration development",
    "test:doctor": "pnpm run cleanup && pnpm run eslintCheck && pnpm run prettierCheck && pnpm run test:unit && pnpm run build:app",
    "test:unit": "ng test --configuration=ci",
    "test:static": "pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck",
    "watch:UT": "ng test --configuration=watch",
    "build:app": "ng build",
    "cleanup": "rimraf .angular/ coverage/ dist/",
    "securityCheck": "pnpm audit",
    "eslintCheck": "eslint \"src/**/*.ts\"",
    "prettierCheck": "prettier --check \"{src,public}/**/*.{ts,js,json,scss,html,md}\"",
    "prepare": "husky",
    "lintStaged": "lint-staged",
    "updatePnpm": "pnpm self-update",
    "bumpDependencies": "pnpm dlx npm-check-updates",
    "postbumpDependencies": "pnpm audit --fix && pnpm i && pnpm test"
  },
  "engines": {
    "node": ">=24.13.0 <25"
  },
  "packageManager": "pnpm@10.29.3",
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.4",
    "@angular/compiler": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/forms": "^21.1.4",
    "@angular/platform-browser": "^21.1.4",
    "@angular/router": "^21.1.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk@>=1.10.0 <=1.25.3": ">=1.26.0",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2"
    }
  }
}
